{
  "name": "@app-runtime-kit/core",
  "version": "0.0.10",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "setup:standalone": "node scripts/setup-standalone.mjs",
    "build:css": "tailwindcss -c tailwind.config.cjs -i styles/input.css -o dist/styles.css --minify",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/fix-dist-import-extensions.mjs && npm run build:css",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run --silent",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=json-summary --coverage.reporter=lcov --coverage.reporter=html --coverage.reportsDirectory=coverage/vitest",
    "test:unit:coverage:target": "node scripts/run-target-coverage.mjs",
    "build": "npm run type-check && npm run lint && npm run test:unit && npm run build:dist",
    "ci:platform": "npm run build"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":                                    { "source": "./index.ts",                                    "default": "./dist/index.js" },
    "./kv":                                 { "source": "./kv/index.ts",                                 "default": "./dist/kv/index.js" },
    "./telemetry":                          { "source": "./telemetry/index.ts",                          "default": "./dist/telemetry/index.js" },
    "./telemetry/keys":                     { "source": "./telemetry/keys.ts",                           "default": "./dist/telemetry/keys.js" },
    "./telemetry/modelUsageAccumulator":    { "source": "./telemetry/modelUsageAccumulator.ts",          "default": "./dist/telemetry/modelUsageAccumulator.js" },
    "./telemetry/subscriptionMetrics":      { "source": "./telemetry/subscriptionMetrics.ts",            "default": "./dist/telemetry/subscriptionMetrics.js" },
    "./telemetry/tierChange":               { "source": "./telemetry/tierChange.ts",                     "default": "./dist/telemetry/tierChange.js" },
    "./telemetry/tierChangeLogger":         { "source": "./telemetry/tierChangeLogger.ts",               "default": "./dist/telemetry/tierChangeLogger.js" },
    "./telemetry/usageKeys":                { "source": "./telemetry/usageKeys.ts",                      "default": "./dist/telemetry/usageKeys.js" },
    "./telemetry/week":                     { "source": "./telemetry/week.ts",                           "default": "./dist/telemetry/week.js" },
    "./swr":                                { "source": "./swr/index.ts",                                "default": "./dist/swr/index.js" },
    "./swr/SWRProvider":                    { "source": "./swr/SWRProvider.tsx",                         "default": "./dist/swr/SWRProvider.js" },
    "./swr/dedupingConfig":                 { "source": "./swr/dedupingConfig.ts",                       "default": "./dist/swr/dedupingConfig.js" },
    "./swr/fetchers":                       { "source": "./swr/fetchers.ts",                             "default": "./dist/swr/fetchers.js" },
    "./settings":                           { "source": "./settings/index.ts",                           "default": "./dist/settings/index.js" },
    "./settings/settingsTabs":              { "source": "./settings/settingsTabs.ts",                    "default": "./dist/settings/settingsTabs.js" },
    "./settings/tierBrandingCore":          { "source": "./settings/tierBrandingCore.ts",                "default": "./dist/settings/tierBrandingCore.js" },
    "./settings/serviceAdapter":            { "source": "./settings/serviceAdapter.ts",                  "default": "./dist/settings/serviceAdapter.js" },
    "./services":                           { "source": "./services/index.ts",                           "default": "./dist/services/index.js" },
    "./services/settingsService":           { "source": "./services/settingsService.ts",                 "default": "./dist/services/settingsService.js" },
    "./services/subscriptionService":       { "source": "./services/subscriptionService.ts",             "default": "./dist/services/subscriptionService.js" },
    "./shared/cn":                          { "source": "./shared/cn.ts",                                "default": "./dist/shared/cn.js" },
    "./styles.css": "./dist/styles.css",
    "./prisma/schema": "./prisma/schema.prisma"
  },
  "files": [
    "dist",
    "prisma/schema.prisma",
    "README.md",
    "LICENSE*"
  ],
  "dependencies": {
    "baseline-browser-mapping": "^2.10.19",
    "caniuse-lite": "^1.0.30001788",
    "clsx": "^2.1.1",
    "swr": "^2.3.8",
    "swr-package": "npm:swr@^2.3.8",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.11",
    "@types/react": "^18.3.3",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.2",
    "happy-dom": "^20.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  }
}
